*Important: Because we are using CIFAR-100 (which has 100 classes instead of 10), we must update the model.*
</VSCode.Cell>
<VSCode.Cell language="python">
import os
# Run this to update the PyTorch model locally to support 100 classes instead of 10
task_file = "quickstart_pytorch/task.py"
if os.path.exists(task_file):
    with open(task_file, "r") as f:
        content = f.read()
    content = content.replace("num_classes=10", "num_classes=100")
    content = content.replace("out_features=10", "out_features=100")
    with open(task_file, "w") as f:
        f.write(content)
    print("Updated task.py for CIFAR-100")
</VSCode.Cell>
<VSCode.Cell language="markdown">
## 3) Choose a partitioner

Change PARTITIONER to try a different split: iid, dirichlet, or shard.
</VSCode.Cell>
<VSCode.Cell language="python">
from flwr_datasets import FederatedDataset
from flwr_datasets.partitioner import IidPartitioner, DirichletPartitioner, ShardPartitioner
from flwr_datasets.visualization import plot_label_distributions

PARTITIONER = "dirichlet"  # change to: iid | dirichlet | shard

def make_partitioner(kind: str, num_partitions: int = 10):
    if kind == "iid":
        return IidPartitioner(num_partitions=num_partitions)
    if kind == "dirichlet":
        return DirichletPartitioner(
            num_partitions=num_partitions,
            partition_by="fine_label",
            alpha=0.3,
            seed=42,
            min_partition_size=0,
        )
    if kind == "shard":
        return ShardPartitioner(
            num_partitions=num_partitions,
            partition_by="fine_label",
            num_shards_per_partition=2,
        )
    raise ValueError(f"Unknown partitioner: {kind}")

partitioner = make_partitioner(PARTITIONER)
fds = FederatedDataset(
    dataset="uoft-cs/cifar100",
    partitioners={"train": partitioner},
)
partitioner = fds.partitioners["train"]
</VSCode.Cell>
<VSCode.Cell language="python">
fig, ax, df = plot_label_distributions(
    partitioner,
    label_name="fine_label",
    plot_type="bar",
    size_unit="absolute",
    partition_id_axis="x",
    legend=False,
    verbose_labels=False,
    title="Per-Client Label Distribution",
)
</VSCode.Cell>
